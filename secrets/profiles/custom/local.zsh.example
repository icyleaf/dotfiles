# ~/.config/zsh/local.zsh — per-device environment variables
#
# This file is deployed by chezmoi from your Secret Profile's encrypted local.zsh.age.
# It is sourced by .zshrc on every shell startup.
#
# To add secrets to this profile:
#   1. Edit this file (plaintext) on the machine that holds the age private key
#   2. Encrypt it:  age -r <your-pubkey> -o secrets/profiles/<profile>/local.zsh.age ~/.config/zsh/local.zsh
#   3. Commit the .age file (never commit the plaintext version)
#
# Example contents:
#   export GITHUB_TOKEN="ghp_..."
#   export B2_KEY="..."
#   export PULUMI_ACCESS_TOKEN="pul-..."
