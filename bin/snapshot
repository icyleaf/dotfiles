#!/usr/bin/env python3
import os
import sys
import json
import datetime
from pathlib import Path

# 获取 dotfiles 仓库根目录与系统家目录
DOTFILES_DIR = Path(__file__).resolve().parent.parent
HOME_DIR = Path.home()
SNAPSHOT_DIR = DOTFILES_DIR / ".scratch" / "snapshots"

def get_timestamp():
    return datetime.datetime.now().strftime("%Y%m%d-%H%M%S")

def scan_symlinks():
    results = {}
    
    # 扫描配置：(目录路径, 是否递归)
    scan_paths = [
        (HOME_DIR, False),  # 仅限家目录第一层（检测 .gitconfig 等）
        (HOME_DIR / ".config", True),  # 递归扫描整个 .config
        (HOME_DIR / ".local/bin", True),  # 递归扫描 bin 路径
    ]
    
    for path, recursive in scan_paths:
        if not path.exists():
            continue
            
        if recursive:
            for root, dirs, files in os.walk(path):
                if ".git" in dirs:
                    dirs.remove(".git")
                for name in files + dirs:
                    p = Path(root) / name
                    if p.is_symlink():
                        try:
                            target = os.readlink(p)
                            resolved_target = Path(target)
                            if not resolved_target.is_absolute():
                                resolved_target = (p.parent / target).resolve()
                            else:
                                resolved_target = resolved_target.resolve()
                                
                            # 判定是否属于当前 dotfiles 仓库管理
                            if str(resolved_target).startswith(str(DOTFILES_DIR)):
                                rel_path = str(p.relative_to(HOME_DIR))
                                results[rel_path] = {
                                    "type": "symlink",
                                    "target": str(resolved_target.relative_to(DOTFILES_DIR)),
                                    "status": "OK" if resolved_target.exists() else "BROKEN"
                                }
                        except Exception:
                            pass
        else:
            for entry in os.scandir(path):
                if entry.is_symlink():
                    try:
                        target = os.readlink(entry.path)
                        resolved_target = Path(target)
                        if not resolved_target.is_absolute():
                            resolved_target = (Path(entry.path).parent / target).resolve()
                        else:
                            resolved_target = resolved_target.resolve()
                            
                        if str(resolved_target).startswith(str(DOTFILES_DIR)):
                            rel_path = str(Path(entry.path).relative_to(HOME_DIR))
                            results[rel_path] = {
                                "type": "symlink",
                                "target": str(resolved_target.relative_to(DOTFILES_DIR)),
                                "status": "OK" if resolved_target.exists() else "BROKEN"
                            }
                    except Exception:
                        pass
                        
    # 特殊系统资源检测：Plymouth 主题
    plymouth_theme = Path("/usr/share/plymouth/themes/achron")
    if plymouth_theme.exists():
        results["/usr/share/plymouth/themes/achron"] = {
            "type": "directory",
            "status": "OK",
            "info": "Plymouth achron theme installed on host system"
        }
        
    return results

def cmd_save(args):
    results = scan_symlinks()
    SNAPSHOT_DIR.mkdir(parents=True, exist_ok=True)
    
    if args:
        filepath = Path(args[0])
    else:
        filepath = SNAPSHOT_DIR / f"snapshot-{get_timestamp()}.json"
        
    with open(filepath, "w", encoding="utf-8") as f:
        json.dump(results, f, indent=2, sort_keys=True)
        
    print(f"Snapshot successfully saved to: {filepath}")

def cmd_diff(args):
    if len(args) < 2:
        print("Usage: ./bin/snapshot diff <file1.json> <file2.json>")
        sys.exit(1)
        
    file1, file2 = Path(args[0]), Path(args[1])
    if not file1.exists() or not file2.exists():
        print("Error: One or both snapshot files do not exist.")
        sys.exit(1)
        
    with open(file1, "r", encoding="utf-8") as f:
        snap1 = json.load(f)
    with open(file2, "r", encoding="utf-8") as f:
        snap2 = json.load(f)
        
    paths1 = set(snap1.keys())
    paths2 = set(snap2.keys())
    
    added = paths2 - paths1
    removed = paths1 - paths2
    common = paths1 & paths2
    
    modified = {}
    for p in common:
        if snap1[p] != snap2[p]:
            modified[p] = (snap1[p], snap2[p])
            
    # 颜色终端高亮
    GREEN = "\033[92m"
    RED = "\033[91m"
    YELLOW = "\033[93m"
    RESET = "\033[0m"
    BOLD = "\033[1m"
    
    print(f"{BOLD}Comparing snapshots:{RESET}")
    print(f"  Old: {file1}")
    print(f"  New: {file2}\n")
    
    if not added and not removed and not modified:
        print("No changes detected. Installation state is identical.")
        return
        
    if added:
        print(f"{GREEN}+++ Added Paths ({len(added)}):{RESET}")
        for p in sorted(added):
            info = snap2[p]
            target_str = f" -> {info['target']}" if info.get("type") == "symlink" else ""
            print(f"  + {p}{target_str} ({info['status']})")
        print()
        
    if removed:
        print(f"{RED}--- Removed Paths ({len(removed)}):{RESET}")
        for p in sorted(removed):
            info = snap1[p]
            target_str = f" -> {info['target']}" if info.get("type") == "symlink" else ""
            print(f"  - {p}{target_str}")
        print()
        
    if modified:
        print(f"{YELLOW}* Modified Paths ({len(modified)}):{RESET}")
        for p in sorted(modified):
            v1, v2 = modified[p]
            print(f"  * {p}:")
            if v1.get("target") != v2.get("target"):
                print(f"    {RED}  - target: {v1.get('target')}{RESET}")
                print(f"    {GREEN}  + target: {v2.get('target')}{RESET}")
            if v1.get("status") != v2.get("status"):
                print(f"    - status: {v1['status']} -> {v2['status']}")
        print()

def main():
    if len(sys.argv) < 2:
        print("Usage:")
        print("  ./bin/snapshot save [output_file.json]")
        print("  ./bin/snapshot diff <old.json> <new.json>")
        sys.exit(1)
        
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    if cmd == "save":
        cmd_save(args)
    elif cmd == "diff":
        cmd_diff(args)
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)

if __name__ == "__main__":
    main()
