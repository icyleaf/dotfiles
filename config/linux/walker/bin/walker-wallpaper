#!/usr/bin/env bash
set -euo pipefail

# define a variable for the wallpaper directory, directory fetch from hyprland config

WALL_DIR="$HOME/.config/omarchy/current/theme/backgrounds/"
THUMB_DIR="$HOME/.cache/wallthumbs"
mkdir -p "$THUMB_DIR"

# Generate Walker entries from existing thumbnails
entries=""
while IFS= read -r img; do
    name="$(basename "$img")"
    hash="$(sha1sum <<< "$img" | awk '{print $1}')"
    thumb="$THUMB_DIR/$hash.jpg"

    # Generate thumbnail if not exists
    if [[ ! -f "$thumb" ]]; then
        if command -v convert >/dev/null; then
            convert -resize 120x120 "$img" "$thumb" 2>/dev/null || cp "$img" "$thumb"
        else
            ln -sf "$img" "$thumb"
        fi
    fi

    entries+="$name\x00icon\x1f$thumb\n"
done < <(find "$WALL_DIR" -type f \( -iname '*.jpg' -o -iname '*.png' -o -iname '*.jpeg' \) 2>/dev/null || true)


echo -e "$entries" | walker --dmenu
