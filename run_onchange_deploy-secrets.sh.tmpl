#!/usr/bin/env bash
# run_onchange_deploy-secrets.sh.tmpl
#
# Deploys encrypted secrets (SSH private keys + shell env vars) from the
# chezmoi source directory to the home directory. Triggered automatically
# by chezmoi apply whenever the content of this rendered script changes
# (i.e., when any .age file in the active profile is modified).
#
# Change-detection manifest (chezmoi re-runs when any entry changes):
{{- range (glob (joinPath .chezmoi.sourceDir "secrets" "base" "*.age")) }}
#   base/{{ base . }} size={{ (stat .).Size }}
{{- end }}
{{- range (glob (joinPath .chezmoi.sourceDir "secrets" "profiles" .machine_profile "*.age")) }}
#   profiles/{{ .machine_profile }}/{{ base . }} size={{ (stat .).Size }}
{{- end }}
{{- range (glob (joinPath .chezmoi.sourceDir "secrets" "profiles" .machine_profile "ssh" "*.age")) }}
#   profiles/{{ .machine_profile }}/ssh/{{ base . }} size={{ (stat .).Size }}
{{- end }}

set -euo pipefail

PROFILE={{ .machine_profile | quote }}
SOURCE_DIR={{ .chezmoi.sourceDir | quote }}
AGE_KEY="{{ .chezmoi.homeDir }}/.local/share/age/default-key.txt"
BASE_DIR="${SOURCE_DIR}/secrets/base"
PROFILE_DIR="${SOURCE_DIR}/secrets/profiles/${PROFILE}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

deploy_age_file() {
  local src="$1"
  local dest="$2"
  age --decrypt -i "${AGE_KEY}" "${src}" > "${dest}"
  chmod 600 "${dest}"
}

ensure_ssh_dir() {
  mkdir -p "${HOME}/.ssh"
  chmod 700 "${HOME}/.ssh"
}

# ---------------------------------------------------------------------------
# Base Secrets — SSH keys common to all devices
# ---------------------------------------------------------------------------

if [ -d "${BASE_DIR}" ]; then
  shopt -s nullglob
  base_keys=("${BASE_DIR}"/*.age)
  shopt -u nullglob

  if [ "${#base_keys[@]}" -gt 0 ]; then
    ensure_ssh_dir
    for key_file in "${base_keys[@]}"; do
      key_name=$(basename "${key_file}" .age)
      deploy_age_file "${key_file}" "${HOME}/.ssh/${key_name}"
    done
  fi
fi

# ---------------------------------------------------------------------------
# Profile Secrets — env vars and device-specific SSH keys
# ---------------------------------------------------------------------------

mkdir -p "${HOME}/.config/zsh"

if [ -d "${PROFILE_DIR}" ] && [ "${PROFILE}" != "custom" ]; then
  # Deploy environment variables
  local_zsh_age="${PROFILE_DIR}/local.zsh.age"
  if [ -f "${local_zsh_age}" ]; then
    deploy_age_file "${local_zsh_age}" "${HOME}/.config/zsh/local.zsh"
  fi

  # Deploy profile-specific SSH keys
  profile_ssh_dir="${PROFILE_DIR}/ssh"
  if [ -d "${profile_ssh_dir}" ]; then
    shopt -s nullglob
    profile_keys=("${profile_ssh_dir}"/*.age)
    shopt -u nullglob

    if [ "${#profile_keys[@]}" -gt 0 ]; then
      ensure_ssh_dir
      for key_file in "${profile_keys[@]}"; do
        key_name=$(basename "${key_file}" .age)
        deploy_age_file "${key_file}" "${HOME}/.ssh/${key_name}"
      done
    fi
  fi
else
  # Custom / unknown profile: deploy scaffold so the shell doesn't error
  scaffold="${SOURCE_DIR}/secrets/profiles/custom/local.zsh.example"
  dest="${HOME}/.config/zsh/local.zsh"
  if [ ! -f "${dest}" ]; then
    cp "${scaffold}" "${dest}"
  fi
  chmod 600 "${dest}"
fi
